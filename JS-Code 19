class Payment extends Thread {
    public void run() {
        System.out.println("Processing payment...");
    }
}

class Order extends Thread {
    public void run() {
        System.out.println("Order confirmed...");
    }
}

public class OnlineShoppingSystem {
    public static void main(String[] args) {
        new Payment().start();
        new Order().start();
    }
}
