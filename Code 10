interface Bank {
    float getInterestRate();
}

class SBI implements Bank {
    public float getInterestRate() { return 6; }
}

class HDFC implements Bank {
    public float getInterestRate() { return 7; }
}

class ICICI implements Bank {
    public float getInterestRate() { return 8; }
}

class Main {
    public static void main(String[] args) {
        Bank b;
        b = new SBI();
        System.out.println(b.getInterestRate());
        b = new HDFC();
        System.out.println(b.getInterestRate());
        b = new ICICI();
        System.out.println(b.getInterestRate());
    }
}
